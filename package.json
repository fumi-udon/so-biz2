{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && npm run build:filament",
        "build:filament": "mkdir -p public/css/filament/admin && npx --yes tailwindcss@3.4.17 -i ./resources/css/filament/admin/theme.css -o ./public/css/filament/admin/theme.css -c ./resources/css/filament/admin/tailwind.config.js --minify",
        "dev": "vite",
        "dev:filament": "mkdir -p public/css/filament/admin && npx --yes tailwindcss@3.4.17 -i ./resources/css/filament/admin/theme.css -o ./public/css/filament/admin/theme.css -c ./resources/css/filament/admin/tailwind.config.js --watch"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^2.0.0",
        "laravel-vite-plugin": "^3.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
