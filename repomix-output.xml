    protected function beforeSave(): void
    {
        $data = $this->form->getState();
        $staffId = $data['staff_id'] ?? null;
        $date = $data['date'] ?? null;
        $meal = $data['meal_type'] ?? null;

        if (! $staffId || ! $date || ! $meal) {
