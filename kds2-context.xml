<script setup>
import { computed } from 'vue';

/**
 * KdsV2Controller の name 形式「商品 (スタイル) + トッピング…」をメイン／オプションに分割する。
 * @param {string} full
 * @returns {{ main: string, options: string }}
 */
function splitKdsTicketDisplayName(full) {
    const s = String(full ?? '').trim();
    if (s === '') {
        return { main: '', options: '' };
    }
    const idxParen = s.indexOf(' (');
    const idxPlus = s.indexOf(' + ');
    if (idxParen === -1 && idxPlus === -1) {
        return { main: s, options: '' };
    }
    const splitAt =
        idxParen === -1 ? idxPlus : idxPlus === -1 ? idxParen : Math.min(idxParen, idxPlus);
    const main = s.slice(0, splitAt).trimEnd();
    const options = s.slice(splitAt).trimStart();
    if (main === '') {
        return { main: s, options: '' };
    }
    return { main, options };
}

const props = defineProps({
    ticket: {
        type: Object,
        required: true,
    },
});

defineEmits(['serve']);

const nameParts = computed(() => splitKdsTicketDisplayName(props.ticket?.name));

const qtyGt1 = computed(() => Number(props.ticket?.qty) > 1);

const rowClass = computed(() => {
    const s = props.ticket?.status;
    if (s === 'served') {
        return 'bg-slate-700 text-slate-300';
    }
    if (s === 'confirmed' || s === 'cooking') {
        return 'bg-rose-900 text-white';
    }
    return 'bg-slate-800 text-slate-200';
});
</script>
