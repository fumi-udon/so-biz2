                <span class="text-base font-semibold leading-tight">{{ nameParts.main }}</span>
                <span v-if="qtyGt1" class="shrink-0 text-base font-semibold">×{{ ticket.qty }}</span>
            </div>
            <span
                v-if="nameParts.options"
                class="w-full break-words text-sm font-normal leading-snug text-rose-200"
            >
                {{ nameParts.options }}
            </span>
