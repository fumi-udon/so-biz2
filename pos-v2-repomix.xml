 * @param {boolean} debugEnabled - page.props.auth.debug（POS2_DEBUG）
 * @param {string} event
 * @param {object} payload
 */
export function pushOrderSubmitTrace(debugStore, debugEnabled, event, payload) {
    if (debugEnabled !== true || !debugStore) {
