    class="fixed inset-x-0 bottom-0 z-50 flex max-h-[90dvh] max-w-full flex-col overflow-x-hidden rounded-t-2xl bg-white text-gray-950 shadow-2xl dark:bg-gray-900 dark:text-white"
    role="dialog"
