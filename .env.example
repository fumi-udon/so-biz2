APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# ブラウザで開く URL と一致させる（Laravel Sail の公開ポート例）
APP_URL=http://localhost:8089
APP_PORT=8089

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Chrome DevTools → Network → Timing: Server-Timing (db / app ms). Livewire TTFB のサーバー側内訳用。
SERVER_TIMING=false

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Laravel Sail + MySQL を使う場合の例（共有DBならプレフィックス推奨）
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=sail
# DB_PASSWORD=password
# DB_TABLE_PREFIX=so2_
# FORWARD_DB_PORT=3308
# FORWARD_PHPMYADMIN_PORT=8090
#
# PHPUnit は MySQL 専用 DB（.env.testing の soya_biz2_test）を使用。テストは ./vendor/bin/sail test で実行。
# DB_USERNAME / DB_PASSWORD は上記と一致させること。.env.testing をカスタムした場合は compose の MySQL と権限を合わせる。

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# KDS キッチン端末: 4桁PIN → shop_id の JSON マップ（例: {"1234":1,"5678":2}）
KDS_PIN_MAP={}

BROADCAST_DRIVER=pusher
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_LOG_TO_CONSOLE=true
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Daily close — Get recettes (external orders API)
DAILY_CLOSE_ORDERS_API_URL=https://bistronippon.com/api/orders
DAILY_CLOSE_ORDERS_API_STORE=main
# 合計待機上限（秒）。Livewire 同期リクエストなので長すぎない値推奨。
DAILY_CLOSE_ORDERS_API_TIMEOUT=20
# 接続確立までの上限（秒）。相手ダウン時に即近く失敗させる。
DAILY_CLOSE_ORDERS_API_CONNECT_TIMEOUT=5
# 営業日境界と end_date の解釈（空=APP_TIMEZONE）。API の日時文字列はこの TZ のローカル時刻として扱う。
# DAILY_CLOSE_ORDERS_API_TZ=Europe/Paris
# true=Jesser と同じ strtotime 集計のみ（比較用）。既定 false=Carbon+上記TZ。
# DAILY_CLOSE_ORDERS_API_LEGACY_STRTOTIME=false
# オーダー1件の金額キー（カンマ区切り・先頭から存在するキーを採用）。既定 total＝POS の会計合計（明細の再計算ではない）。
# DAILY_CLOSE_ORDERS_API_SUM_KEYS=total
# true=JSONは出さず件数・合計のみ storage/logs に記録
# DAILY_CLOSE_ORDERS_API_DEBUG_LOG=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# レシート・POS 既定 TVA 率（%）。TVA_TN を優先し、未設定なら POS_RECEIPT_VAT_DEFAULT、どちらもなければ 19。
# TVA_TN=13
# POS_RECEIPT_VAT_DEFAULT=19

# POS ダッシュボード既定店舗（bnops_ 本番は 3）
# POS_DEFAULT_SHOP_ID=3
# true=Realtime チャンネルを上記店舗に限定（Ghost Order 防止）
# POS_ENFORCE_REALTIME_SHOP_SCOPE=true

# 客注フォーム・厨房モニター共通のテーブル番号（カンマ区切り）。未設定時は 1,2,3,4
# RESTAURANT_TABLES=1,2,3,4,5,6

# レジ締め「管理者 Door」参照用 PIN（空だと Door から許容区分・履歴を見られません）
DAILY_CLOSE_DOOR_SECRET=

# クローズ完了後の WhatsApp 報告先（国番号付き・数字のみ推奨。例: 21612345678）
# WHATSAPP_MANAGER_NUMBER=

# POS V2: 会計確定時の users.id（PIN のみのため web ガードの id が無い。ブリッジ Cloture で必須）
# POS2_SETTLEMENT_ACTOR_USER_ID=1
