APP_NAME="Bistro Pivot Testing"
APP_ENV=testing
APP_KEY=base64:3AYV+y2modmv/3iLdAUyVYrBzLr/9bEoy57CHD400tU=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Sail コンテナ内から `mysql` サービスへ接続（./vendor/bin/sail test）
# ホストで ./vendor/bin/phpunit する場合: CLI の PHP に pdo_mysql が要る（php -m | grep pdo_mysql）。
# "could not find driver" のとき例: sudo apt install php8.3-mysql（php -v の版に合わせる）
# DB_USERNAME / DB_PASSWORD はホストの .env と一致させること（Sail 既定: sail / password）
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=soya_biz2_test
DB_USERNAME=sail
DB_PASSWORD=password
DB_TABLE_PREFIX=so2_

BROADCAST_CONNECTION=null
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
